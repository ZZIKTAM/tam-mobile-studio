<?xml version="1.0" encoding="utf-8"?>
<!-- 4x2 Date Widget — light glass style matching liquid_glass_preview.html -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Header row: icon + "Tam Studio" | D-Day badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅"
            android:textSize="15sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:text="Tam Studio"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#0F0F1E" />

        <TextView
            android:id="@+id/tv_dday"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_badge_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:text="D-?"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#0A84FF" />
    </LinearLayout>

    <!-- Divider -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="6dp"
        android:background="#1A000000" />

    <!-- "다음 일정" label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="다음 일정"
        android:textSize="10sp"
        android:textColor="#6B6B7A"
        android:layout_marginBottom="5dp" />

    <!-- Next event card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_event_card_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="9dp">

        <TextView
            android:id="@+id/tv_next_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅"
            android:textSize="16sp"
            android:layout_marginEnd="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_next_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="일정 없음"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#0F0F1E"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_next_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="10sp"
                android:textColor="#6B6B7A"
                android:layout_marginTop="1dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Mini calendar bar — 5 upcoming date chips -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- chip 0 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tv_chip_day_0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="일"
                android:textSize="9sp"
                android:textColor="#6B6B7A" />
            <TextView
                android:id="@+id/tv_chip_date_0"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="--"
                android:textSize="11sp"
                android:textColor="#0F0F1E" />
        </LinearLayout>

        <!-- chip 1 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tv_chip_day_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="일"
                android:textSize="9sp"
                android:textColor="#6B6B7A" />
            <TextView
                android:id="@+id/tv_chip_date_1"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="--"
                android:textSize="11sp"
                android:textColor="#0F0F1E" />
        </LinearLayout>

        <!-- chip 2 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tv_chip_day_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="일"
                android:textSize="9sp"
                android:textColor="#6B6B7A" />
            <TextView
                android:id="@+id/tv_chip_date_2"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="--"
                android:textSize="11sp"
                android:textColor="#0F0F1E" />
        </LinearLayout>

        <!-- chip 3 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tv_chip_day_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="일"
                android:textSize="9sp"
                android:textColor="#6B6B7A" />
            <TextView
                android:id="@+id/tv_chip_date_3"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="--"
                android:textSize="11sp"
                android:textColor="#0F0F1E" />
        </LinearLayout>

        <!-- chip 4 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tv_chip_day_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="일"
                android:textSize="9sp"
                android:textColor="#6B6B7A" />
            <TextView
                android:id="@+id/tv_chip_date_4"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="--"
                android:textSize="11sp"
                android:textColor="#0F0F1E" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
